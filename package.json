{
  "name": "cc-companion",
  "version": "1.2.0",
  "description": "A desktop companion app that monitors Claude Code sessions and serves curated content while you wait",
  "author": "CC Companion Contributors",
  "license": "MIT",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac"
  },
  "dependencies": {
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "vitest": "^4.1.2"
  },
  "build": {
    "appId": "com.cc-companion.app",
    "productName": "CC Companion",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns"
    },
    "files": [
      "electron/**/*",
      "src/**/*",
      "assets/**/*"
    ]
  }
}
